# PROJECT AURA — ignores
build/
.gradle/
.cxx/
*.o
*.exe
local.properties
.idea/
# Placeholder model binaries are not committed; generate via tools/ (see
# apps/android/src/main/assets/models/README.md)
apps/android/src/main/assets/models/*.onnx
apps/android/src/main/assets/models/*.pt
# Speech Commands dataset (~2.3GB) downloaded by tools/train_kws_model.py
.data/
# Wake-word audio datasets + generated TTS clips + Piper voice models (large, regenerable
# via wakeword_datagen/run_all.py). Real recordings live outside git or in DVC.
dataset/
wakeword_datagen/output/
wakeword_datagen/models/
wakeword_datagen/**/*.wav
*.wav
# Vendored native libs extracted from AARs (regenerated at build time)
third_party/onnxruntime/lib/
# NOTE: gradle/wrapper/gradle-wrapper.jar IS committed (v1) — do not ignore *.jar
# TTS engines: isolated venvs + cloned repos + downloaded model weights (multi-GB, set up by
# the multi-engine datagen workflow — Piper-sample-gen, Kokoro, Indic-TTS, etc.)
wakeword_datagen/venvs/
wakeword_datagen/piper-sample-generator/
wakeword_datagen/**/*.onnx
wakeword_datagen/**/*.pt
wakeword_datagen/**/*.pth
wakeword_datagen/**/*.tar*
wakeword_datagen/**/*.mp3
# Python cruft
__pycache__/
*.pyc
*.pyo
.venv/
venv/
graphify-out/