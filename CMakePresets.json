{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 22, "patch": 0 },
  "configurePresets": [
    {
      "name": "host-debug",
      "displayName": "Host debug (unit + golden tests)",
      "description": "Platform-independent core built for the host with tests, instrumentation on.",
      "binaryDir": "${sourceDir}/build/host-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "AURA_PLATFORM": "host",
        "AURA_ENABLE_ONNXRUNTIME": "OFF",
        "AURA_ENABLE_DEBUG_LOCK_INSTRUMENTATION": "ON",
        "AURA_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "host-release",
      "inherits": "host-debug",
      "displayName": "Host release",
      "binaryDir": "${sourceDir}/build/host-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "AURA_ENABLE_DEBUG_LOCK_INSTRUMENTATION": "OFF"
      }
    },
    {
      "name": "android-arm64-debug",
      "displayName": "Android arm64-v8a debug",
      "description": "Standalone Android cross-build (Gradle normally drives this via externalNativeBuild).",
      "binaryDir": "${sourceDir}/build/android-arm64-debug",
      "toolchainFile": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-26",
        "AURA_PLATFORM": "android",
        "AURA_ENABLE_ONNXRUNTIME": "ON",
        "AURA_ENABLE_DEBUG_LOCK_INSTRUMENTATION": "ON",
        "AURA_BUILD_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    { "name": "host-debug", "configurePreset": "host-debug" },
    { "name": "host-release", "configurePreset": "host-release" },
    { "name": "android-arm64-debug", "configurePreset": "android-arm64-debug" }
  ],
  "testPresets": [
    {
      "name": "host-debug",
      "configurePreset": "host-debug",
      "output": { "outputOnFailure": true }
    }
  ]
}
